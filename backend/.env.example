# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─────────────────────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/task_manager_dev?schema=public"

# ─────────────────────────────────────────────
# JWT Secrets (generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))")
# ─────────────────────────────────────────────
JWT_ACCESS_SECRET=replace-with-64-char-random-string
JWT_REFRESH_SECRET=replace-with-different-64-char-random-string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# ─────────────────────────────────────────────
# CORS (comma-separated origins)
# ─────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────
LOG_LEVEL=debug

# ─────────────────────────────────────────────
# Bcrypt
# ─────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ─────────────────────────────────────────────
# Seed admin (used once by `npm run prisma:seed` to create the first admin user)
# Pick a strong password — never commit real values, only set them in your local
# .env or in your hosting provider's secret store.
# ─────────────────────────────────────────────
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=Admin
